{
  "name": "use-auto-callback-ref",
  "version": "1.0.0",
  "license": "MIT",
  "author": {
    "name": "Liam Martens",
    "email": "hi@liammartens.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LiamMartens/use-callback-ref"
  },
  "files": [
    "lib"
  ],
  "sideEffects": false,
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "format": "oxfmt",
    "lint:fix": "oxlint --fix",
    "build:esm": "swc -C module.type=es6 ./src -d ./lib/esm",
    "build:cjs": "swc -C module.type=commonjs ./src -d ./lib/cjs",
    "build:types": "tsc -p .",
    "build": "run-p build:*",
    "prepare": "husky"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.59",
    "@swc/core": "^1.3.25",
    "@types/react": "^18.0.26",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react": "^18.2.0",
    "typescript": "^4.9.4"
  },
  "peerDependencies": {
    "react": ">=17.0.0||>=18.0.0"
  }
}
