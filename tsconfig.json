{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "lib",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES6",
    "jsx": "preserve",
    "declaration": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "paths": {
      "@/": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
